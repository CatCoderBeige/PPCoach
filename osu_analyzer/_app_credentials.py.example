"""Template for your own osu! app credentials.

1. Copy this file to `_app_credentials.py` (same folder).
2. Fill in your own client ID/secret (register at
   https://osu.ppy.sh/home/account/edit#new-oauth-application).
3. `_app_credentials.py` is bundled into the .exe automatically by PyInstaller
   and is NOT checked in (see .gitignore) - end users never see or need it.
"""

CLIENT_ID = "YOUR_OSU_CLIENT_ID"
CLIENT_SECRET = "YOUR_OSU_CLIENT_SECRET"
